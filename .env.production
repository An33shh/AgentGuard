# =============================================================================
# AgentGuard — Production Configuration Template
# Safe to commit — no secrets. Put API keys and passwords in .env (gitignored).
# =============================================================================

ENV=production

# ---------------------------------------------------------------------------
# Database — PostgreSQL (required in production)
# Override DATABASE_URL in .env with your actual credentials
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://agentguard:CHANGEME@localhost:5432/agentguard

# ---------------------------------------------------------------------------
# Redis — required for async enrichment worker
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# AgentGuard Core
# ---------------------------------------------------------------------------
AGENTGUARD_POLICY_PATH=policies/default.yaml
AGENTGUARD_LOG_LEVEL=WARNING
AGENTGUARD_JSON_LOGS=true
AGENTGUARD_DEV_RELOAD=false
AGENTGUARD_ANALYZER_TIMEOUT=10.0
AGENTGUARD_ANALYZER_MODEL=claude-sonnet-4-6
AGENTGUARD_HEDGE_AFTER=3.0

# Do NOT auto-seed demo data in production
AGENTGUARD_AUTO_SEED=false

# ---------------------------------------------------------------------------
# API Authentication — REQUIRED in production. Generate and store in .env:
#   AGENTGUARD_API_KEY=<random string>
#   AGENTGUARD_JWT_SECRET=$(python -c "import secrets; print(secrets.token_hex(32))")
# ---------------------------------------------------------------------------
# AGENTGUARD_API_KEY=        # set in .env
# AGENTGUARD_JWT_SECRET=     # set in .env
AGENTGUARD_JWT_EXPIRE_SECONDS=3600

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
AGENTGUARD_RATE_LIMIT=120
AGENTGUARD_RATE_LIMIT_WINDOW=60

# ---------------------------------------------------------------------------
# FastAPI
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=https://your-domain.com

# ---------------------------------------------------------------------------
# OpenTelemetry
# ---------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=agentguard
