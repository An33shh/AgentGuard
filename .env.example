# =============================================================================
# AgentGuard — Environment Secrets
# Copy to .env and fill in your values. Never commit .env.
#
# Non-secret defaults are in .env.dev (development) and .env.production.
# This file only needs the secrets that can't be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Provider (pick one — API key goes here, model config in .env.dev)
# ---------------------------------------------------------------------------

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# AGENTGUARD_ANALYZER=openai
# OPENAI_API_KEY=sk-...
# AGENTGUARD_ANALYZER_MODEL=gpt-4o

# Groq
# AGENTGUARD_ANALYZER=groq
# GROQ_API_KEY=gsk_...
# AGENTGUARD_ANALYZER_MODEL=llama-3.1-70b-versatile

# Ollama (local, no key needed — set in .env.dev instead)
# AGENTGUARD_ANALYZER=ollama
# AGENTGUARD_ANALYZER_MODEL=llama3.1

# Any OpenAI-compatible endpoint
# AGENTGUARD_ANALYZER=openai
# AGENTGUARD_BASE_URL=https://your-endpoint/v1
# OPENAI_API_KEY=your-key
# AGENTGUARD_ANALYZER_MODEL=your-model

# ---------------------------------------------------------------------------
# Database
# Local dev: docker compose up -d postgres  (DATABASE_URL set in .env.dev)
# Override here if connecting to a non-default host/credentials:
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://agentguard:agentguard@localhost:5747/agentguard

# SQLite fallback (zero-setup, no Docker needed — data persists in agentguard.db):
# DATABASE_URL=sqlite+aiosqlite:///./agentguard.db

# ---------------------------------------------------------------------------
# API Authentication (production — leave unset in dev to disable auth)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
# AGENTGUARD_API_KEY=your-secret-api-key
# AGENTGUARD_JWT_SECRET=your-jwt-signing-secret
