# =============================================================================
# AgentGuard — Development Configuration
# Safe to commit — no secrets. Put API keys in .env (gitignored).
# =============================================================================

ENV=development

# ---------------------------------------------------------------------------
# Database — PostgreSQL via docker-compose
# Run: docker compose up -d postgres redis
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://agentguard:agentguard@localhost:5432/agentguard

# ---------------------------------------------------------------------------
# Redis — required for async enrichment worker
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# AgentGuard Core
# ---------------------------------------------------------------------------
AGENTGUARD_POLICY_PATH=policies/default.yaml
AGENTGUARD_LOG_LEVEL=INFO
AGENTGUARD_JSON_LOGS=false
AGENTGUARD_DEV_RELOAD=true
AGENTGUARD_ANALYZER_TIMEOUT=10.0
AGENTGUARD_ANALYZER_MODEL=claude-sonnet-4-6
AGENTGUARD_HEDGE_AFTER=3.0

# Auto-seed 6 OpenClaw demo scenarios on first boot (when DB is empty)
AGENTGUARD_AUTO_SEED=true

# ---------------------------------------------------------------------------
# FastAPI
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------------------------------------------------------------------------
# OpenTelemetry (disabled in dev by default)
# ---------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=agentguard
